# Demo defaults for one-command setup via `make demo`.
# Hostnames point at the compose network service names (not localhost).
# MOBSF_API_KEY is injected into the MobSF container so the REST key is
# fixed and the app uses the same value.

MOBSF_URL=http://mobsf:8000
MOBSF_API_KEY=ikusa_demo_fixed_key_0123456789abcdef

LLM_PROVIDER=ollama
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b

# Set OPENAI_API_KEY and LLM_PROVIDER=openai for ~10s triage instead of ~3min.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

SCAN_STORAGE=/var/lib/ikusa/scans
